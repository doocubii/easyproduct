{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easyproduct.dev/schemas/ia.v1.schema.json",
  "title": "EasyProduct 화면·기능 구조(IA) — 기능 인덱스 블록 (payload v1)",
  "description": "IA 문서 하단의 기능 인덱스 블록(전체 FEAT 기능을 한 블록에 담음)의 계약. 봉투(frontmatter)는 별도 규약이다.",
  "type": "object",
  "required": ["features"],
  "additionalProperties": true,
  "properties": {
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "audience", "status"],
        "additionalProperties": true,
        "properties": {
          "id":       { "type": "string", "pattern": "^FEAT\\.[a-z][a-zA-Z0-9]*\\.[a-z][a-zA-Z0-9]*$", "description": "기능 anchor. FEAT.<domain>.<name>(도메인·기능명은 소문자 camelCase)." },
          "label":    { "type": "string", "description": "사람이 보는 기능 이름(바뀌어도 id는 유지)." },
          "audience": { "enum": ["user", "admin"], "description": "프론트(user) / 백오피스(admin). FEAT.admin.*는 admin." },
          "status":   { "enum": ["current", "later", "removed"], "description": "현역 / 부가(나중에) / 제거됨." }
        }
      }
    }
  }
}
