{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easyproduct.dev/schemas/ui-components.v1.schema.json",
  "title": "EasyProduct UI 컴포넌트 인벤토리 — 컴포넌트 목록 블록 (payload v1)",
  "description": "UI 컴포넌트 인벤토리의 컴포넌트 정의를 기계가 읽는 사본. 인벤토리(사람용 정의)가 원본이고 이 블록은 그 미러. id뿐 아니라 파라미터·variants·규격까지 담아 소프트웨어가 산문을 파싱하지 않고도 컴포넌트를 얻게 한다. 봉투(frontmatter)는 별도 규약이다.",
  "type": "object",
  "required": ["components"],
  "additionalProperties": true,
  "properties": {
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scope", "spec"],
        "additionalProperties": true,
        "properties": {
          "id":       { "type": "string", "pattern": "^UI\\.[A-Za-z][A-Za-z0-9]*(\\.[A-Za-z][A-Za-z0-9]*)*$", "description": "컴포넌트 anchor. 프리미티브 UI.<컴포넌트>(예: UI.table) / 중앙 UI.<카테고리>.<컴포넌트>[.<variant>] / 로컬 UI.FEAT.<도메인>.<기능명>[.<화면종류>].<컴포넌트명>. UI. 뒤 1마디 이상." },
          "scope":    { "enum": ["central", "local"], "description": "중앙 재사용(central) / 화면 전용 로컬(local)." },
          "label":    { "type": "string", "description": "사람이 읽는 이름(선택)." },
          "default":  { "type": "string", "description": "기본 문구(값 안 넘길 때) — 없으면 생략." },
          "params": {
            "type": "array",
            "description": "호출 시 넘기는 파라미터. 이름만이 아니라 종류·뜻을 담는다(뜻 없는 이름 금지).",
            "items": {
              "type": "object",
              "required": ["name", "type", "desc"],
              "additionalProperties": true,
              "properties": {
                "name":     { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9]*$", "description": "파라미터 이름(camelCase)." },
                "type":     { "enum": ["string", "number", "boolean", "list", "node"], "description": "종류. node=내부 콘텐츠 영역(slot/body 등)." },
                "required": { "type": "boolean", "description": "필수 여부(선택 필드)." },
                "desc":     { "type": "string", "description": "무엇을 뜻하는지 한 줄. 필수 — 뜻 없는 파라미터는 두지 않는다." },
                "values":   { "type": "array", "items": { "type": "string" }, "description": "값이 정해진 경우(enum) 허용 값들. 예: state → guest/member/orgAdmin." }
              }
            }
          },
          "variants": {
            "type": "array",
            "description": "variants/states. 이름 + 뜻.",
            "items": {
              "type": "object",
              "required": ["name", "desc"],
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string", "description": "variant/state 이름." },
                "desc": { "type": "string", "description": "그 상태가 무엇인지 한 줄. 필수." }
              }
            }
          },
          "spec":     { "type": "string", "description": "규격(크기·radius 등 실제 값, 디자인 토큰 참조 포함) — 산문 '규격'을 옮긴 정의 본문. 이 블록의 존재 이유이므로 필수." }
        }
      }
    }
  }
}
