{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://easyproduct.dev/schemas/data-model.v1.schema.json",
  "title": "EasyProduct 데이터 모델 — 그룹 블록 (payload v1)",
  "description": "데이터 모델 문서의 각 그룹 표 아래 인라인 JSON 미러 한 개(= 그룹 하나)의 계약. 봉투(frontmatter)는 별도 규약이다.",
  "type": "object",
  "required": ["id", "group", "label", "fields"],
  "additionalProperties": true,
  "properties": {
    "id":    { "type": "string", "pattern": "^DATA\\.[a-z][a-zA-Z]*$", "description": "그룹의 크로스도큐먼트 anchor. DATA.<group> 형식." },
    "group": { "type": "string", "pattern": "^[a-z][a-zA-Z]*$", "description": "영문 소문자 단수 그룹명(접두사 없는 로컬 이름)." },
    "label": { "type": "string" },
    "description": { "type": "string" },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type", "required", "source"],
        "additionalProperties": true,
        "properties": {
          "name":     { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$", "description": "camelCase 필드명. 전체 변수는 <group>.<name>." },
          "label":    { "type": "string" },
          "type":     { "enum": ["string", "number", "datetime", "date", "boolean", "list", "image"] },
          "required": { "type": "boolean" },
          "source":   { "enum": ["auto:managed", "auto:preset", "user"] },
          "usedIn":   { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "additionalProperties": true,
        "properties": {
          "type":   { "enum": ["hasOne", "hasMany", "belongsTo", "manyToMany"] },
          "target": { "type": "string", "description": "대상 그룹의 로컬 이름 또는 DATA.<group> anchor." },
          "description": { "type": "string" }
        }
      }
    }
  }
}
